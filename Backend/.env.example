PORT=

# Include the database name in the path (e.g. .../budgetbuddy?...) — without it MongoDB uses "test"
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/budgetbuddy?retryWrites=true&w=majority
MONGO_DB_NAME=budgetbuddy

JWT_SECRET=your-long-random-secret

# Optional extra CORS origins (comma-separated)
CORS_ORIGINS=
